<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background"
    tools:context=".reportActivity">


    <!-- Стильный TabLayout -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_layout_wallets"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/tab_bg"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tabGravity="fill"
        app:tabIndicatorColor="#10B981"
        app:tabIndicatorHeight="3dp"
        app:tabMode="scrollable"
        app:tabSelectedTextColor="#1F2937"
        app:tabTextColor="#6B7280" />

    <!-- ScrollView с контентом -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tab_layout_wallets">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Дата "От" -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:strokeColor="#E5E7EB"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:id="@+id/linearLayout1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/card_bg"

                    android:padding="16dp">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/textFromDate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:focusable="false"
                            android:hint="Дата От"
                            android:inputType="date" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <Button
                        android:id="@+id/butFromDate"
                        android:layout_width="50dp"
                        android:layout_height="56dp"
                        android:backgroundTint="#4F46E5"
                        android:onClick="setFromDate"
                        android:padding="8dp"
                        android:text="🗓"
                        android:textSize="24sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Дата "До" -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:strokeColor="#E5E7EB"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:id="@+id/linearLayout2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/card_bg"

                    android:padding="16dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/textBeforeDate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:focusable="false"
                            android:hint="Дата До"
                            android:inputType="date" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <Button
                        android:id="@+id/butBeforeDate"
                        android:layout_width="50dp"
                        android:layout_height="56dp"
                        android:backgroundTint="#4F46E5"
                        android:text="🗓"
                        android:textSize="24sp"
                        android:padding="8dp"
                        android:onClick="setFromDate" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Графики в карточках -->
            <com.github.mikephil.charting.charts.PieChart
                android:id="@+id/pieChartIncome"
                android:layout_width="match_parent"
                android:layout_height="350dp"
                android:layout_marginBottom="16dp" />

            <com.github.mikephil.charting.charts.PieChart
                android:id="@+id/pieChartExpense"
                android:layout_width="match_parent"
                android:layout_height="350dp"
                android:layout_marginBottom="16dp" />

            <com.github.mikephil.charting.charts.BarChart
                android:id="@+id/barChartStacked"
                android:layout_width="match_parent"
                android:layout_height="350dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
